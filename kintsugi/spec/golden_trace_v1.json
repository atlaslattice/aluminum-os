{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/splitmerge420/aluminum-os/kintsugi/spec/golden_trace_v1.json",
  "title": "GoldenTrace Event v1.0",
  "description": "Append-only audit event for the Kintsugi governance spine. Every action, failure, repair, and constitutional decision produces a GoldenTrace.",
  "type": "object",
  "required": ["trace_id", "timestamp", "source", "event_type", "sphere_tag", "aluminum_layer", "payload", "integrity"],
  "properties": {
    "trace_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for this trace event"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of event"
    },
    "source": {
      "type": "object",
      "required": ["repo", "module", "function"],
      "properties": {
        "repo": { "type": "string", "description": "Source repo (e.g., aluminum-os, uws, sheldonbrain-rag-api)" },
        "module": { "type": "string", "description": "Module path (e.g., constitutional/consent_kernel)" },
        "function": { "type": "string", "description": "Function or method name" },
        "line": { "type": "integer", "description": "Optional line number" }
      }
    },
    "event_type": {
      "type": "string",
      "enum": [
        "action", "failure", "repair", "golden_seam",
        "invariant_check", "invariant_violation",
        "consent_granted", "consent_denied",
        "council_vote", "council_consensus", "council_dissent",
        "model_route", "model_fallback",
        "query", "ingestion", "classification",
        "amendment_proposed", "amendment_enacted",
        "ghost_seat_invoked", "human_override"
      ],
      "description": "Type of trace event"
    },
    "severity": {
      "type": "string",
      "enum": ["trace", "info", "warning", "error", "critical", "golden"],
      "default": "info",
      "description": "'golden' indicates a kintsugi repair — failure turned into strength"
    },
    "sphere_tag": {
      "type": "string",
      "pattern": "^(H[0-9]{1,2}\\.S[0-9]{1,3}|S[0-9]{1,3})$",
      "description": "144-sphere ontology tag (e.g., H7.S3 or S069)"
    },
    "aluminum_layer": {
      "type": "string",
      "enum": ["L1-Constitutional", "L2-Kernel", "L3-Engine", "L4-Service", "L5-Extension"],
      "description": "Which Aluminum OS layer produced this event"
    },
    "invariants_checked": {
      "type": "array",
      "items": { "type": "string", "pattern": "^INV-[0-9]{1,2}$" },
      "description": "Which constitutional invariants were verified"
    },
    "council_context": {
      "type": "object",
      "properties": {
        "session_id": { "type": "string" },
        "model": { "type": "string", "description": "Which AI model (claude, gemini, grok, copilot, deepseek)" },
        "role": { "type": "string", "description": "Council role (router, prime_expert, wildcard, reality_sync, logistics, witness)" },
        "vote": { "type": "string", "enum": ["approve", "reject", "abstain", "dissent"] },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "kintsugi": {
      "type": "object",
      "description": "Present when this trace represents a golden repair",
      "properties": {
        "original_failure_trace_id": { "type": "string", "format": "uuid" },
        "repair_strategy": { "type": "string" },
        "strength_gained": { "type": "string", "description": "What the system learned from this failure" },
        "beauty_score": { "type": "number", "minimum": 0, "maximum": 1, "description": "How elegantly the repair was executed" }
      }
    },
    "payload": {
      "type": "object",
      "description": "Event-specific data (varies by event_type)",
      "additionalProperties": true
    },
    "integrity": {
      "type": "object",
      "required": ["hash_algorithm", "hash"],
      "properties": {
        "hash_algorithm": { "type": "string", "enum": ["sha3-256", "ml-dsa-87", "fn-dsa-512"] },
        "hash": { "type": "string", "description": "Hash of all fields except integrity block" },
        "previous_trace_hash": { "type": "string", "description": "Hash chain link to previous trace (append-only)" },
        "signature": { "type": "string", "description": "Optional PQC signature" }
      }
    }
  }
}